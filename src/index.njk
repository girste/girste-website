---
layout: base.njk
title: "Stefano Girard — Digital Product Builder"
description: "Stefano Girard — Digital Product Builder. Designing and building end-to-end digital experiences with an AI-first approach."
---
        <div class="container">
            <section class="hero">
                <h1>Digital Product<br>Builder.</h1>
                <button id="theme-pill">press me</button>
                <p class="subhead">
                    Fully AI-native, deeply technical and genuinely passionate about where this is all going. Design is where I started, innovation is where I live.
                </p>

                <div class="simple-split">
                    <div class="split-opt">
                        <h3>Selection 01</h3>
                        <a href="/pages/tech.html">AI-First Stack →</a>
                    </div>
                    <div class="split-opt">
                        <h3>Selection 02</h3>
                        <a href="/pages/design.html">Design Portfolio →</a>
                    </div>
                </div>

                <span class="featured-label">Featured Projects</span>
                <div class="home-projects">
                    {% for p in projects %}
                    {% if p.featured_home %}
                    <a href="projects/{{ p.slug }}.html" class="project-card">
                        <div class="img-wrap">
                            <img src="{{ p.cover_image }}" alt="{{ p.name }}" loading="lazy">
                        </div>
                        <div class="project-info">
                            <h4>{{ p.name }}</h4>
                            <span>{{ p.card_tag }}</span>
                        </div>
                    </a>
                    {% endif %}
                    {% endfor %}
                </div>
            </section>
        </div>
<script>
(function(){
    var themes=['','theme-1','theme-2','theme-3','theme-4','theme-5','theme-6'];
    var labels=['press me','once more?','sure?','really?','...','ok.','HELP'];
    var FONTS='https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Space+Mono:wght@400;700&family=Comfortaa:wght@700&family=Bebas+Neue&family=Comic+Neue:wght@700&family=Orbitron:wght@400;700&display=swap';
    var fontsLoaded=false;
    function loadFonts(){if(fontsLoaded)return;var l=document.createElement('link');l.rel='stylesheet';l.href=FONTS;document.head.appendChild(l);fontsLoaded=true;}

    var WA_COLORS=['#FF0000','#FF6600','#FF9900','#FFCC00','#CCDD00','#33AA00','#00AA88','#0088CC','#0044FF','#6600CC','#AA00BB','#DD0077','#FF0044','#FF3300','#FF7700'];
    function applyWordArt(){
        var h1=document.querySelector('h1');
        if(!h1||h1.dataset.waOrig)return;
        h1.dataset.waOrig=h1.innerHTML;
        var html=h1.innerHTML,result='',ci=0;
        for(var i=0;i<html.length;i++){
            if(html[i]==='<'){var e=html.indexOf('>',i);result+=html.slice(i,e+1);i=e;}
            else if(html[i]===' '||html[i]==='\n'){result+=html[i];}
            else{result+='<span class="wl" style="color:'+WA_COLORS[ci%WA_COLORS.length]+'">'+html[i]+'</span>';ci++;}
        }
        h1.innerHTML=result;
    }
    function removeWordArt(){
        var h1=document.querySelector('h1');
        if(h1&&h1.dataset.waOrig){h1.innerHTML=h1.dataset.waOrig;delete h1.dataset.waOrig;}
    }

    function applyMiniScreen(){
        if(document.getElementById('mini-screen'))return;
        var shell=document.createElement('div');
        shell.id='mini-screen';
        shell.style.cssText='position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.32);width:100vw;height:100vh;transform-origin:center center;background:#fff;overflow:hidden;';
        var hdr=document.querySelector('header.site-header');
        var mn=document.querySelector('main');
        hdr.style.position='absolute';
        shell.appendChild(hdr);
        shell.appendChild(mn);
        document.body.appendChild(shell);
    }
    function removeMiniScreen(){
        var shell=document.getElementById('mini-screen');
        if(!shell)return;
        var hdr=shell.querySelector('header.site-header');
        var mn=shell.querySelector('main');
        if(hdr){hdr.style.position='';document.body.insertBefore(hdr,document.body.firstChild);}
        if(mn){document.body.insertBefore(mn,shell);}
        shell.remove();
    }

    var pill=document.getElementById('theme-pill');
    pill.dataset.themeIndex='0';
    pill.addEventListener('click',function(){
        loadFonts();
        var idx=parseInt(this.dataset.themeIndex||'0');
        if(idx===4)removeWordArt();
        if(idx===5)removeMiniScreen();
        if(idx>0)document.body.classList.remove(themes[idx]);
        idx=(idx+1)%themes.length;
        this.dataset.themeIndex=String(idx);
        if(idx>0)document.body.classList.add(themes[idx]);
        if(idx===4)applyWordArt();
        if(idx===5)applyMiniScreen();
        this.textContent=labels[idx];
    });
})();
</script>
