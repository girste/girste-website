<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width">
    {% if description %}<meta name="description" content="{{ description }}">{% endif %}
    <title>{{ title }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css?v=27">
</head>
<body>
    <header class="site-header">
        <div class="container">
            <nav class="main-nav">
                <a href="/" class="nav-brand">Stefano Girard</a>
                <div class="nav-links">
                    <a href="/pages/design.html"{% if activeNav == "design" %} class="active"{% endif %}>Design</a>
                    <a href="/pages/tech.html"{% if activeNav == "tech" %} class="active"{% endif %}>Tech</a>
                    <a href="/pages/about.html"{% if activeNav == "about" %} class="active"{% endif %}>Me</a>
                </div>
            </nav>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>
    <script>
    document.querySelector('.nav-brand').addEventListener('click',function(e){
        var pill=document.getElementById('theme-pill');
        if(pill){
            var idx=parseInt(pill.dataset.themeIndex||'0');
            if(idx===4){var h1=document.querySelector('h1');if(h1&&h1.dataset.waOrig){h1.innerHTML=h1.dataset.waOrig;delete h1.dataset.waOrig;}}
            if(idx===5){var shell=document.getElementById('mini-screen');if(shell){var hdr=shell.querySelector('header.site-header');var mn=shell.querySelector('main');if(hdr){hdr.style.position='';document.body.insertBefore(hdr,document.body.firstChild);}if(mn){document.body.insertBefore(mn,shell);}shell.remove();}}
            if(idx>0)document.body.classList.remove('theme-'+idx);
            pill.dataset.themeIndex='0';
            pill.textContent='press me';
        }
        if(window.location.pathname==='/'||window.location.pathname==='/index.html'){e.preventDefault();}
    });
    </script>
</body>
</html>
