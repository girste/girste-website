---
layout: base.njk
title: "Portfolio — Stefano Girard"
description: "Design portfolio featuring branding, web design, and visual identity projects."
activeNav: design
permalink: /pages/design.html
---
        <div class="container">
            <section class="design-section" style="padding: 12rem 0 6rem;">
                <h1>Portfolio</h1>
                <p class="subhead">A curated selection of digital products and visual identities. From creative direction to production-ready design systems.</p>

                <div class="home-projects" style="margin-top: 6rem;">
                    {% for p in projects %}
                    {% if p.featured_portfolio %}
                    <a href="/projects/{{ p.slug }}.html" class="project-card">
                        <div class="img-wrap">
                            <img src="{{ p.cover_image }}" alt="{{ p.name }}" loading="lazy">
                        </div>
                        <div class="project-info">
                            <h4>{{ p.name }}</h4>
                            <span>{{ p.card_tag }}</span>
                        </div>
                    </a>
                    {% endif %}
                    {% endfor %}
                </div>

                <div style="margin-top: 4rem; text-align: center; border-top: 1px solid var(--border); padding-top: 4rem;">
                    <a href="/pages/archive.html" style="font-size: 1.5rem; font-weight: 500; text-decoration: underline;">View Full Project Archive (20+) →</a>
                </div>
            </section>
        </div>
